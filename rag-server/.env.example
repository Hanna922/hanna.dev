# Local rag-server defaults
GEMINI_API_KEY=

SERVER_PORT=8080

QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_USE_TLS=false
QDRANT_COLLECTION=hanna-dev-documents
QDRANT_BOOTSTRAP_ENABLED=true

RAG_EMBEDDING_MODEL=gemini-embedding-001
RAG_EMBEDDING_DIMENSION=3072
RAG_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com
RAG_TOP_K=5
RAG_CONTEXT_MAX_CHARS=12000

INTERNAL_HEADER_NAME=X-Internal-Api-Key
INTERNAL_QUERY_API_KEY=local-query-key
INTERNAL_ADMIN_API_KEY=local-admin-key

RAG_SERVER_URL=http://localhost:8080
RAG_SERVER_QUERY_API_KEY=local-query-key
RAG_SERVER_ADMIN_API_KEY=local-admin-key
