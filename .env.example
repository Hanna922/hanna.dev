# Shared local environment for Astro, scripts, and rag-server
GOOGLE_GENERATIVE_AI_API_KEY=

RAG_SERVER_URL=http://localhost:8080

INTERNAL_HEADER_NAME=X-Internal-Api-Key
INTERNAL_QUERY_API_KEY=local-query-key
INTERNAL_ADMIN_API_KEY=local-admin-key

# Optional client-specific overrides. Leave blank to reuse INTERNAL_* keys.
RAG_SERVER_QUERY_API_KEY=
RAG_SERVER_ADMIN_API_KEY=
